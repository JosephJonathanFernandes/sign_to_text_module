# Environment Variables — ISL Sign-to-Text API
# Copy this file to .env and fill in values before running.
# .env is gitignored — never commit real values.

# ─────────────────────────────────────
# API Server
# ─────────────────────────────────────

# Port the API listens on
PORT=8000

# Enable debug mode (returns top-5 probabilities in responses)
# NEVER set true in production
DEBUG=false

# ─────────────────────────────────────
# CORS — Allowed Origins
# ─────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your actual domain(s).
# In development, you may use: http://localhost:3000,http://localhost:5173
# If unset, defaults to empty string in production (rejects cross-origin requests)
# WARNING: Do NOT set to * in production — it exposes your API to any website.

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────
# Model / Asset Paths (optional overrides)
# ─────────────────────────────────────
# These default to the paths in src/core/config.py.
# Override only if your assets are in non-standard locations.

# ENSEMBLE_DIR=assets/ensemble
# HAND_LANDMARKER_MODEL=models/hand_landmarker.task
# FACE_LANDMARKER_MODEL=models/face_landmarker.task
